{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gachachess",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-13",
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GameRoom"]
    }
  ]
}
